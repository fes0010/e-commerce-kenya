# ============================================================================
# Bagisto E-Commerce Platform - Dokploy Production Environment
# ============================================================================
# This file contains production-ready environment variables for deploying
# Bagisto on Dokploy with Docker Swarm.
#
# IMPORTANT: 
# - Replace all placeholder values with your actual production values
# - Never commit this file with real credentials to version control
# - Use Dokploy's environment variable management for sensitive data
# ============================================================================

# ─── Application Settings ───────────────────────────────────────────────────
APP_NAME="Bagisto Commerce"
APP_ENV=production
APP_KEY=base64:M5rLVTaHtyawT7YG99b5813TC49Z+rNReYzC3XPUhl4=
APP_DEBUG=false
APP_DEBUG_ALLOWED_IPS=
APP_URL=https://your-domain.com
APP_ADMIN_URL=admin
APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_CURRENCY=USD

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Database Configuration ─────────────────────────────────────────────────
# For Dokploy deployment, use the MySQL service name or container IP
# If using Dokploy's MySQL service: use service name (e.g., mysql-service)
# If using external MySQL: use the host IP or domain
DB_CONNECTION=mysql
DB_HOST=10.0.1.29
DB_PORT=3306
DB_DATABASE=bagisto
DB_USERNAME=root
DB_PASSWORD=Enterpassword001.
DB_PREFIX=

# ─── Session Configuration ──────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.your-domain.com

# ─── Broadcasting & Queue ───────────────────────────────────────────────────
BROADCAST_CONNECTION=redis
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis

# ─── Cache Configuration ────────────────────────────────────────────────────
CACHE_STORE=redis
CACHE_PREFIX=bagisto_cache

MEMCACHED_HOST=127.0.0.1

# ─── Redis Configuration ────────────────────────────────────────────────────
# For Dokploy: use Redis service name or container IP
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

RESPONSE_CACHE_ENABLED=true

# ─── Mail Configuration ─────────────────────────────────────────────────────
# Configure your SMTP settings for production
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_ENCRYPTION=tls

MAIL_FROM_ADDRESS=noreply@your-domain.com
MAIL_FROM_NAME="${APP_NAME}"
ADMIN_MAIL_ADDRESS=admin@your-domain.com
ADMIN_MAIL_NAME="Admin"
CONTACT_MAIL_ADDRESS=contact@your-domain.com
CONTACT_MAIL_NAME="Contact"

# ─── AWS S3 Configuration (Optional) ────────────────────────────────────────
# For production file storage, consider using S3 or compatible service
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Vite Build Configuration ───────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
VITE_HOST=0.0.0.0
VITE_PORT=5173

# ─── Payment Gateway Configuration ──────────────────────────────────────────
# PayPal
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Razorpay
RAZORPAY_KEY=
RAZORPAY_SECRET=

# PayU
PAYU_MERCHANT_KEY=
PAYU_SALT=
PAYU_MODE=live

# ─── Social Login Configuration ─────────────────────────────────────────────
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/customer/social-login/google/callback"

# Facebook OAuth
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/customer/social-login/facebook/callback"

# Twitter OAuth
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI="${APP_URL}/customer/social-login/twitter/callback"

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI="${APP_URL}/customer/social-login/github/callback"

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI="${APP_URL}/customer/social-login/linkedin/callback"

# ─── Elasticsearch Configuration ────────────────────────────────────────────
# For Dokploy: use Elasticsearch service name or container IP
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=http
ELASTICSEARCH_USER=
ELASTICSEARCH_PASS=
ELASTICSEARCH_INDEX_PREFIX=bagisto_

# ─── AI/MagicAI Configuration ───────────────────────────────────────────────
# OpenAI API for AI features
OPENAI_API_KEY=
OPENAI_ORGANIZATION=

# ─── Security & Performance ─────────────────────────────────────────────────
# CORS Configuration
CORS_ALLOWED_ORIGINS="${APP_URL}"
CORS_ALLOWED_METHODS="GET,POST,PUT,DELETE,OPTIONS"
CORS_ALLOWED_HEADERS="Content-Type,Authorization,X-Requested-With"

# Trusted Proxies (for load balancers)
TRUSTED_PROXIES=*

# ─── Monitoring & Analytics ─────────────────────────────────────────────────
# Google Analytics
GOOGLE_ANALYTICS_ID=

# Facebook Pixel
FACEBOOK_PIXEL_ID=

# ─── Backup & Maintenance ───────────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30

# ─── Docker & Dokploy Specific ──────────────────────────────────────────────
# These are used by Docker and Dokploy for container orchestration
DOCKER_PLATFORM=linux/amd64

# Health check endpoint
HEALTH_CHECK_PATH=/health

# ─── ECC Integration (Optional) ─────────────────────────────────────────────
# If you want to integrate ECC for AI-assisted development
ANTHROPIC_API_KEY=
GITHUB_TOKEN=

# Astraflow / UModelVerse (OpenAI-compatible)
ASTRAFLOW_API_KEY=
ASTRAFLOW_MODEL=gpt-4o-mini
ASTRAFLOW_BASE_URL=https://api.umodelverse.ai/v1

# ─── Additional Production Settings ─────────────────────────────────────────
# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Image Optimization
IMAGE_DRIVER=gd
IMAGE_CACHE_ENABLED=true
IMAGE_CACHE_LIFETIME=2628000

# Full Page Cache
FPC_ENABLED=true
FPC_LIFETIME=86400

# GDPR Compliance
GDPR_ENABLED=true
COOKIE_CONSENT_ENABLED=true

# ============================================================================
# DEPLOYMENT CHECKLIST
# ============================================================================
# Before deploying to Dokploy, ensure you have:
# 
# 1. ✓ Updated APP_URL with your production domain
# 2. ✓ Set APP_ENV=production and APP_DEBUG=false
# 3. ✓ Generated a new APP_KEY (php artisan key:generate)
# 4. ✓ Configured database credentials (DB_HOST, DB_DATABASE, etc.)
# 5. ✓ Set up Redis for caching and sessions
# 6. ✓ Configured SMTP for email delivery
# 7. ✓ Added payment gateway credentials
# 8. ✓ Set up SSL certificate for HTTPS
# 9. ✓ Configured trusted proxies for load balancer
# 10. ✓ Set up backup strategy
# 11. ✓ Configured monitoring and logging
# 12. ✓ Run migrations: php artisan migrate --force
# 13. ✓ Build frontend assets: npm run build (in Admin, Shop, Installer)
# 14. ✓ Clear and cache config: php artisan config:cache
# 15. ✓ Clear and cache routes: php artisan route:cache
# 16. ✓ Clear and cache views: php artisan view:cache
# ============================================================================
